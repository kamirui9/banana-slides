# ========================================
# Banana Slides 生产环境配置
# 部署到公司服务器使用
# ========================================

# AI Provider 格式配置
# "gemini": 使用 Google GenAI SDK
# "openai": 使用 OpenAI SDK 格式 (推荐用于 aihubmix)
AI_PROVIDER_FORMAT=openai

# OpenAI 格式配置（当 AI_PROVIDER_FORMAT=openai 时使用）
# 替换为你的 API Key
OPENAI_API_KEY=your-api-key-here
# aihubmix 代理地址
OPENAI_API_BASE=https://aihubmix.com/v1
# 超时时间（秒）
OPENAI_TIMEOUT=300.0
# 最多重试次数
OPENAI_MAX_RETRIES=2

# Gemini 格式配置（如果需要使用 Gemini 格式，取消以下注释）
# GOOGLE_API_KEY=your-api-key-here
# GOOGLE_API_BASE=https://aihubmix.com/gemini
# GENAI_TIMEOUT=300.0
# GENAI_MAX_RETRIES=2

# AI 模型配置
# aihubmix 支持的模型列表：https://aihubmix.com/models
TEXT_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-3.1-flash-image-preview

# Flask 配置
LOG_LEVEL=INFO
FLASK_ENV=production
# 生产环境请修改为随机字符串
SECRET_KEY=please-change-this-to-a-random-secret-key-in-production
PORT=5000

# CORS 配置（重要！部署到服务器后需要修改）
# 格式：http://服务器IP:端口 或 http://域名
# 多个地址用逗号分隔
# 示例：CORS_ORIGINS=http://192.168.1.100:3333,https://ppt.yourcompany.com
CORS_ORIGINS=http://your-server-ip:3333

# 并发配置
# 根据服务器性能调整
MAX_DESCRIPTION_WORKERS=5
MAX_IMAGE_WORKERS=8

# MinerU 文件解析服务配置
# 建议申请自己的 token
MINERU_TOKEN=your-mineru-token-here
MINERU_API_BASE=https://mineru.net

# 图片识别模型配置
IMAGE_CAPTION_MODEL=gemini-3-flash-preview

# 输出语言配置
# 可选值: 'zh' (中文), 'ja' (日本語), 'en' (English), 'auto' (自动)
OUTPUT_LANGUAGE=zh

# ========================================
# 生产环境镜像源配置（国内服务器推荐）
# ========================================

# Docker Hub 镜像源
DOCKER_REGISTRY=docker.1ms.run/

# GitHub Container Registry 镜像源
GHCR_REGISTRY=ghcr.nju.edu.cn/

# Debian apt 镜像源
APT_MIRROR=mirrors.aliyun.com

# PyPI 镜像源
PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple

# npm 镜像源
NPM_REGISTRY=https://registry.npmmirror.com/
